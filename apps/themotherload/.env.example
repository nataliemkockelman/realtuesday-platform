# Copy this to .env.local for local dev. On Vercel, add these in
# Project Settings → Environment Variables (or via `vercel env add`).
#
# All four are OPTIONAL — the site degrades gracefully when a key is missing
# (form still validates and returns 200, just logs to console instead of
# saving / sending). Set them to activate real backend storage and email.

# Supabase — server-side only. Service-role key bypasses RLS so we can write
# to the subscribers table from the API route.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxx

# Resend — transactional email. Until themomload.com is verified in Resend,
# leave RESEND_FROM_EMAIL unset to use the shared onboarding sender.
RESEND_API_KEY=re_xxxxxxxxxxxxxx
RESEND_FROM_EMAIL=the Motherload <hello@themomload.com>
RESEND_REPLY_TO=natalie@themomload.com
